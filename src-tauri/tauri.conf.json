{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Pet Desktop",
  "version": "0.1.0",
  "identifier": "com.local.codexpetdesktop",
  "build": {
    "frontendDist": "../src",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Codex Pet Desktop",
        "url": "renderer.html",
        "width": 320,
        "height": 340,
        "resizable": false,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "shadow": false,
        "backgroundColor": "#00000000",
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$RESOURCE/**",
          "$HOME/.codex/pets/**",
          "../resources/pets/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": {
      "../resources/pets": "pets"
    },
    "windows": {}
  }
}
